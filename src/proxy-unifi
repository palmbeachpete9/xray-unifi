#!/bin/sh
# proxy-unifi - GUI-less Xray-core proxy client (VLESS/Trojan/Shadowsocks) for UniFi Cloud Gateways.
#
# It runs an Xray WireGuard inbound that the gateway's *native* WireGuard VPN
# Client connects to over loopback, and forwards everything out a proxy server.
# Because the tunnel is a real, controller-managed WireGuard VPN Client, it shows
# up in the UniFi UI (VPN -> VPN Client) and in Policy Engine -> Policy Table.
#
# POSIX sh on purpose: UniFi OS ships dash/busybox-ish environments.

set -eu

# --------------------------------------------------------------------------
# Paths / constants
# --------------------------------------------------------------------------
ROOT="/data/proxy-unifi"
BIN_DIR="$ROOT/bin"
ETC_DIR="$ROOT/etc"
WG_DIR="$ETC_DIR/wg"
XRAY="$BIN_DIR/xray"
SBIN="$BIN_DIR/sing-box"
CONFIG="$ETC_DIR/config.json"
OUTBOUND_LINK="$ETC_DIR/link.txt"
ENGINE_FILE="$ETC_DIR/engine"               # active engine: "xray" or "singbox"
SETTINGS="$ETC_DIR/settings.env"
MKCONFIG="$BIN_DIR/mkconfig.py"
MKSB="$BIN_DIR/mksingbox.py"
SERVICE_NAME="proxy-unifi"
# (no RUN_DIR: xray runs under systemd, no pidfile needed)
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
ONBOOT_DST="/data/on_boot.d/15-proxy-unifi.sh"

# SIP003 plugin support (Shadowsocks)
PLUGINS_DIR="$ROOT/plugins"
PLUGIN_ENV="$ETC_DIR/plugin.env"            # systemd EnvironmentFile (SS_* vars); present => plugin active
PLUGIN_BIN_FILE="$ETC_DIR/plugin.bin"       # one line: absolute path to the plugin binary
PLUGIN_SERVICE_NAME="proxy-unifi-plugin"
PLUGIN_SERVICE_FILE="/etc/systemd/system/${PLUGIN_SERVICE_NAME}.service"

XRAY_RELEASE_BASE="https://github.com/XTLS/Xray-core/releases/latest/download"
GEO_BASE="https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download"
V2RAY_PLUGIN_RELEASES="https://github.com/shadowsocks/v2ray-plugin/releases"
SINGBOX_RELEASES="https://github.com/SagerNet/sing-box/releases"

# defaults (overridable via settings.env)
WG_LISTEN="127.0.0.1"
WG_PORT="51821"
WG_MTU="1340"
WG_KEEPALIVE="25"
XRAY_ADDR="10.7.0.1/32"
UNIFI_ADDR="10.7.0.2/32"
INNER_DNS="8.8.8.8"
LOGLEVEL="warning"
PING_MODE="get"
PING_URL="https://www.gstatic.com/generate_204"
PING_TIMEOUT="5"

# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------
c_red()   { printf '\033[31m%s\033[0m\n' "$*"; }
c_grn()   { printf '\033[32m%s\033[0m\n' "$*"; }
c_ylw()   { printf '\033[33m%s\033[0m\n' "$*"; }
c_bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
info()    { printf '   %s\n' "$*"; }
err()     { c_red "error: $*" >&2; }
fatal()   { err "$*"; exit 1; }

need_root() {
    [ "$(id -u)" = "0" ] || fatal "must be run as root (you are on a UniFi gateway via SSH, use 'root')."
}

load_settings() {
    # shellcheck source=/dev/null
    [ -f "$SETTINGS" ] && . "$SETTINGS" || true
}

save_settings() {
    mkdir -p "$ETC_DIR"
    cat > "$SETTINGS" <<EOF
# proxy-unifi settings - managed by the CLI ('proxy set <key> <value>'). Safe to edit by hand.
WG_LISTEN="$WG_LISTEN"
WG_PORT="$WG_PORT"
WG_MTU="$WG_MTU"
WG_KEEPALIVE="$WG_KEEPALIVE"
XRAY_ADDR="$XRAY_ADDR"
UNIFI_ADDR="$UNIFI_ADDR"
INNER_DNS="$INNER_DNS"
LOGLEVEL="$LOGLEVEL"
PING_MODE="$PING_MODE"
PING_URL="$PING_URL"
PING_TIMEOUT="$PING_TIMEOUT"
EOF
}

have() { command -v "$1" >/dev/null 2>&1; }

py() {
    if have python3; then python3 "$@";
    elif have python; then python "$@";
    else fatal "python3 is required but was not found on this gateway.";
    fi
}

# Generate a WireGuard keypair -> prints "PRIVATE PUBLIC" on one line.
gen_keypair() {
    if have wg; then
        _priv="$(wg genkey)"
        _pub="$(printf '%s' "$_priv" | wg pubkey)"
    elif have openssl; then
        _tmp="$(mktemp)"
        openssl genpkey -algorithm X25519 -out "$_tmp" 2>/dev/null \
            || fatal "openssl could not generate an X25519 key"
        _priv="$(openssl pkey -in "$_tmp" -outform DER 2>/dev/null | tail -c 32 | base64)"
        _pub="$(openssl pkey -in "$_tmp" -pubout -outform DER 2>/dev/null | tail -c 32 | base64)"
        rm -f "$_tmp"
    else
        fatal "need either 'wg' or 'openssl' to generate WireGuard keys"
    fi
    printf '%s %s\n' "$_priv" "$_pub"
}

ensure_keys() {
    mkdir -p "$WG_DIR"
    chmod 700 "$WG_DIR"
    # migrate legacy key names (xray-only era) -> engine-neutral names, so an
    # upgrade reuses the existing keypair instead of regenerating (which would
    # break the already-applied UniFi WireGuard VPN Client).
    if [ -f "$WG_DIR/xray_private.key" ] && [ ! -f "$WG_DIR/wg_private.key" ]; then
        mv "$WG_DIR/xray_private.key" "$WG_DIR/wg_private.key"
    fi
    if [ -f "$WG_DIR/xray_public.key" ] && [ ! -f "$WG_DIR/wg_public.key" ]; then
        mv "$WG_DIR/xray_public.key" "$WG_DIR/wg_public.key"
    fi
    if [ ! -f "$WG_DIR/wg_private.key" ] || [ ! -f "$WG_DIR/unifi_private.key" ]; then
        info "generating WireGuard keypairs (local + UniFi side)..."
        # split "PRIV PUB" without word-splitting/globbing (base64 is glob-safe, but be strict)
        _kp="$(gen_keypair)"; printf '%s' "${_kp% *}" > "$WG_DIR/wg_private.key";  printf '%s' "${_kp#* }" > "$WG_DIR/wg_public.key"
        _kp="$(gen_keypair)"; printf '%s' "${_kp% *}" > "$WG_DIR/unifi_private.key"; printf '%s' "${_kp#* }" > "$WG_DIR/unifi_public.key"
        chmod 600 "$WG_DIR"/*.key
    fi
}

arch_slug() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64-v8a" ;;
        x86_64|amd64)  echo "64" ;;
        armv7l|armhf)  echo "arm32-v7a" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# Go-style arch slug used by v2ray-plugin / most SIP003 plugin releases.
plugin_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64|amd64)  echo "amd64" ;;
        armv7l|armhf)  echo "arm" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# Map a SIP003 plugin name (as it appears in the link) to its binary filename.
plugin_binfile() {
    case "$1" in
        simple-obfs|obfs-local) echo "obfs-local" ;;
        v2ray-plugin)           echo "v2ray-plugin" ;;
        *)                      echo "$1" ;;   # generic: binary named exactly as the plugin
    esac
}

# Download the v2ray-plugin binary into $PLUGINS_DIR (latest release, arch-matched).
cmd_install_plugins() {
    mkdir -p "$PLUGINS_DIR"
    _pa="$(plugin_arch)"
    _tag="$(curl -fsSLI "$V2RAY_PLUGIN_RELEASES/latest" 2>/dev/null | tr -d '\r' \
            | awk -F'/tag/' 'tolower($0) ~ /^location:/ {print $2}' | tail -1)"
    [ -n "$_tag" ] || _tag="v1.3.2"   # fallback pin if the redirect can't be read
    _url="$V2RAY_PLUGIN_RELEASES/download/${_tag}/v2ray-plugin-linux-${_pa}-${_tag}.tar.gz"
    _tmp="$(mktemp -d)"
    info "downloading v2ray-plugin ${_tag} (${_pa}) ..."
    if have curl; then
        curl -fsSL "$_url" -o "$_tmp/p.tgz" || { rm -rf "$_tmp"; err "v2ray-plugin download failed"; return 1; }
    elif have wget; then
        wget -qO "$_tmp/p.tgz" "$_url" || { rm -rf "$_tmp"; err "v2ray-plugin download failed"; return 1; }
    else
        rm -rf "$_tmp"; err "need curl or wget to download v2ray-plugin"; return 1
    fi
    if have tar; then
        tar xzf "$_tmp/p.tgz" -C "$_tmp" || { rm -rf "$_tmp"; err "could not extract v2ray-plugin"; return 1; }
    else
        rm -rf "$_tmp"; err "need tar to extract v2ray-plugin"; return 1
    fi
    if [ -f "$_tmp/v2ray-plugin_linux_${_pa}" ]; then
        install -m 0755 "$_tmp/v2ray-plugin_linux_${_pa}" "$PLUGINS_DIR/v2ray-plugin.new"
        mv -f "$PLUGINS_DIR/v2ray-plugin.new" "$PLUGINS_DIR/v2ray-plugin"
        c_grn "v2ray-plugin installed."
    else
        rm -rf "$_tmp"; err "v2ray-plugin archive layout unexpected"; return 1
    fi
    rm -rf "$_tmp"
}

# --------------------------------------------------------------------------
# Engine selection (xray vs sing-box)
# --------------------------------------------------------------------------
# Which engine handles a link: "xray", "singbox", or "" (unsupported).
engine_for_link() {
    case "$1" in
        vless://*|vmess://*|trojan://*) echo xray; return ;;
        hysteria2://*|hy2://*|tuic://*) echo singbox; return ;;
        ss://*)
            _pn="$(py "$MKCONFIG" --link "$1" --print-plugin 2>/dev/null | cut -f1)"
            if [ -z "$_pn" ]; then echo xray; return; fi   # plain SS -> xray
            case "$_pn" in
                obfs-local|simple-obfs|v2ray-plugin) echo singbox ;;  # sing-box runs these in-process
                *) echo xray ;;                                      # exotic plugin -> xray external runner
            esac
            return ;;
    esac
    echo ""
}

current_engine() {
    if [ -f "$ENGINE_FILE" ]; then cat "$ENGINE_FILE"
    elif [ -f "$OUTBOUND_LINK" ]; then engine_for_link "$(cat "$OUTBOUND_LINK")"
    else echo xray; fi
}

# map our (xray-style) loglevel to sing-box's vocabulary
sb_loglevel() {
    case "$LOGLEVEL" in
        warning) echo warn ;;
        none)    echo fatal ;;
        debug|info|error) echo "$LOGLEVEL" ;;
        *) echo warn ;;
    esac
}

sb_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64|amd64)  echo "amd64" ;;
        armv7l|armhf)  echo "armv7" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

cmd_install_singbox() {
    mkdir -p "$BIN_DIR"
    _sa="$(sb_arch)"
    _tag="$(curl -fsSLI "$SINGBOX_RELEASES/latest" 2>/dev/null | tr -d '\r' \
            | awk -F'/tag/' 'tolower($0) ~ /^location:/ {print $2}' | tail -1)"
    [ -n "$_tag" ] || { err "could not resolve sing-box latest version"; return 1; }
    _ver="${_tag#v}"
    _url="$SINGBOX_RELEASES/download/${_tag}/sing-box-${_ver}-linux-${_sa}.tar.gz"
    _tmp="$(mktemp -d)"
    info "downloading sing-box ${_tag} (${_sa}) ..."
    if have curl; then
        curl -fsSL "$_url" -o "$_tmp/sb.tgz" || { rm -rf "$_tmp"; err "sing-box download failed"; return 1; }
    elif have wget; then
        wget -qO "$_tmp/sb.tgz" "$_url" || { rm -rf "$_tmp"; err "sing-box download failed"; return 1; }
    else
        rm -rf "$_tmp"; err "need curl or wget to download sing-box"; return 1
    fi
    have tar || { rm -rf "$_tmp"; err "need tar to extract sing-box"; return 1; }
    tar xzf "$_tmp/sb.tgz" -C "$_tmp" || { rm -rf "$_tmp"; err "could not extract sing-box"; return 1; }
    _b="$(find "$_tmp" -name sing-box -type f | head -1)"
    [ -n "$_b" ] || { rm -rf "$_tmp"; err "sing-box binary not found in archive"; return 1; }
    install -m 0755 "$_b" "$SBIN.new" && mv -f "$SBIN.new" "$SBIN"
    rm -rf "$_tmp"
    c_grn "sing-box installed: $("$SBIN" version 2>/dev/null | head -1)"
}

ensure_singbox() {
    [ -x "$SBIN" ] || cmd_install_singbox || true
    [ -x "$SBIN" ] || fatal "sing-box is required for this link but could not be installed"
}

# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------

cmd_install_binary() {
    mkdir -p "$BIN_DIR"
    slug="$(arch_slug)"
    url="${XRAY_RELEASE_BASE}/Xray-linux-${slug}.zip"
    tmp="$(mktemp -d)"
    info "downloading xray-core ($slug) ..."
    if have curl; then
        curl -fsSL "$url" -o "$tmp/xray.zip" || fatal "download failed: $url"
    elif have wget; then
        wget -qO "$tmp/xray.zip" "$url" || fatal "download failed: $url"
    else
        fatal "need curl or wget to download xray-core"
    fi
    if have unzip; then
        unzip -oq "$tmp/xray.zip" -d "$tmp" || fatal "unzip failed"
    else
        py -c "import zipfile,sys; zipfile.ZipFile('$tmp/xray.zip').extractall('$tmp')" \
            || fatal "could not extract xray.zip (no unzip and python failed)"
    fi
    [ -f "$tmp/xray" ] || fatal "downloaded archive did not contain an xray binary"
    # Install via temp + atomic rename. Overwriting the file in place with `install`
    # would fail with ETXTBSY ("Text file busy") while the service is running; a
    # rename swaps the inode and leaves the running process on the old one.
    install -m 0755 "$tmp/xray" "$XRAY.new"
    mv -f "$XRAY.new" "$XRAY"
    # geo data ships inside the xray zip, so it refreshes on every core update.
    if [ -f "$tmp/geoip.dat" ];   then install -m 0644 "$tmp/geoip.dat"   "$BIN_DIR/geoip.dat";   fi
    if [ -f "$tmp/geosite.dat" ]; then install -m 0644 "$tmp/geosite.dat" "$BIN_DIR/geosite.dat"; fi
    rm -rf "$tmp"
    c_grn "xray-core installed: $("$XRAY" version 2>/dev/null | head -1)"
    # Pre-stage / refresh the v2ray-plugin SIP003 binary (best-effort).
    cmd_install_plugins || c_ylw "v2ray-plugin not installed (continuing); install it later with: proxy update"
    # Pre-stage / refresh the sing-box engine (best-effort).
    cmd_install_singbox || c_ylw "sing-box not installed (continuing); needed only for hysteria2/tuic/ss+plugin links"
}

write_service() {
    # ExecStart depends on the active engine (xray vs sing-box).
    if [ "$(cat "$ENGINE_FILE" 2>/dev/null || echo xray)" = "singbox" ]; then
        _exec="$SBIN run -c $CONFIG"
    else
        _exec="$XRAY run -config $CONFIG"
    fi
    # If a SIP003 plugin (xray external runner) is active, order xray after it.
    _dep=""
    if [ -f "$PLUGIN_ENV" ]; then
        _dep="Requires=${PLUGIN_SERVICE_NAME}.service
After=${PLUGIN_SERVICE_NAME}.service"
    fi
    cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=proxy-unifi (WireGuard->proxy bridge)
After=network-online.target nss-lookup.target
Wants=network-online.target
# Don't crash-loop before a link has been imported.
ConditionPathExists=$CONFIG
$_dep

[Service]
Type=simple
ExecStart=$_exec
Environment=XRAY_LOCATION_ASSET=$BIN_DIR
WorkingDirectory=$ROOT
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
}

write_plugin_service() {
    _pbin="$(cat "$PLUGIN_BIN_FILE")"
    cat > "$PLUGIN_SERVICE_FILE" <<EOF
[Unit]
Description=proxy-unifi SIP003 plugin
After=network-online.target
Wants=network-online.target
ConditionPathExists=$PLUGIN_ENV

[Service]
Type=simple
EnvironmentFile=$PLUGIN_ENV
ExecStart=$_pbin
Restart=on-failure
RestartSec=3
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
}

# Reconcile the systemd units with the current plugin state (PLUGIN_ENV present?).
apply_plugin_units() {
    if [ -f "$PLUGIN_ENV" ] && [ -f "$PLUGIN_BIN_FILE" ]; then
        write_plugin_service
        write_service
        systemctl daemon-reload 2>/dev/null || true
        systemctl enable "$PLUGIN_SERVICE_NAME" >/dev/null 2>&1 || true
    else
        systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
        rm -f "$PLUGIN_SERVICE_FILE"
        write_service
        systemctl daemon-reload 2>/dev/null || true
    fi
}

install_service() {
    apply_plugin_units
    systemctl enable "$SERVICE_NAME" >/dev/null 2>&1 || true
}

# Build + validate a config from the given link and, only on success, swap it
# into place. Never mutates stored state (link.txt) on failure.
# Detect a SIP003 plugin in the link and verify its binary is available.
# Sets PLG_* globals (PLG_ACTIVE=1/0). Fatals if a required plugin binary is missing.
_plugin_detect() {
    PLG_ACTIVE=0
    _spec="$(py "$MKCONFIG" --link "$1" --print-plugin 2>/dev/null || true)"
    [ -n "$_spec" ] || return 0
    PLG_NAME="$(printf '%s' "$_spec" | cut -f1)"
    PLG_OPTS="$(printf '%s' "$_spec" | cut -f2)"
    PLG_HOST="$(printf '%s' "$_spec" | cut -f3)"
    PLG_PORT="$(printf '%s' "$_spec" | cut -f4)"
    PLG_LPORT="$(printf '%s' "$_spec" | cut -f5)"
    _bf="$(plugin_binfile "$PLG_NAME")"
    PLG_BIN="$PLUGINS_DIR/$_bf"
    if [ ! -x "$PLG_BIN" ] && [ "$_bf" = "v2ray-plugin" ]; then
        cmd_install_plugins || true
    fi
    [ -x "$PLG_BIN" ] || fatal "SIP003 plugin '$PLG_NAME' is not installed. Place its binary at: $PLG_BIN"
    PLG_ACTIVE=1
}

# Commit plugin state to disk (EnvironmentFile + bin path) and reconcile units.
_plugin_commit() {
    if [ "${PLG_ACTIVE:-0}" = "1" ]; then
        mkdir -p "$ETC_DIR"
        # systemd EnvironmentFile: literal KEY=VALUE, never shell-sourced -> injection-safe
        {
            printf 'SS_LOCAL_HOST=127.0.0.1\n'
            printf 'SS_LOCAL_PORT=%s\n'  "$PLG_LPORT"
            printf 'SS_REMOTE_HOST=%s\n' "$PLG_HOST"
            printf 'SS_REMOTE_PORT=%s\n' "$PLG_PORT"
            printf 'SS_PLUGIN_OPTIONS=%s\n' "$PLG_OPTS"
        } > "$PLUGIN_ENV"
        chmod 600 "$PLUGIN_ENV"
        printf '%s' "$PLG_BIN" > "$PLUGIN_BIN_FILE"
    else
        rm -f "$PLUGIN_ENV" "$PLUGIN_BIN_FILE"
    fi
    apply_plugin_units
}

_build_config() {
    _bl="$1"
    ensure_keys
    _eng="$(engine_for_link "$_bl")"
    [ -n "$_eng" ] || fatal "unsupported link (expected vless/vmess/trojan/ss/hysteria2/tuic)"
    wg_priv="$(cat "$WG_DIR/wg_private.key")"
    unifi_pub="$(cat "$WG_DIR/unifi_public.key")"
    mkdir -p "$ETC_DIR"
    tmpcfg="$(mktemp)"
    if [ "$_eng" = "singbox" ]; then
        ensure_singbox
        PLG_ACTIVE=0    # sing-box runs SIP003 plugins in-process; no external xray plugin
        py "$MKSB" \
            --link "$_bl" --port "$WG_PORT" \
            --secret-key "$wg_priv" --peer-pubkey "$unifi_pub" \
            --address "$XRAY_ADDR" --mtu "$WG_MTU" --loglevel "$(sb_loglevel)" \
            > "$tmpcfg" || { rm -f "$tmpcfg"; fatal "config generation failed (check the link)"; }
        if [ -x "$SBIN" ]; then
            "$SBIN" check -c "$tmpcfg" >/dev/null 2>&1 || {
                rm -f "$tmpcfg"; fatal "sing-box rejected the generated config"
            }
        fi
    else
        # verify any (exotic) SIP003 plugin binary BEFORE mutating anything
        _plugin_detect "$_bl"
        # optional --dns, injected via positional params so it stays properly quoted
        set --
        [ -n "$INNER_DNS" ] && set -- --dns "$INNER_DNS"
        py "$MKCONFIG" \
            --link "$_bl" \
            --listen "$WG_LISTEN" \
            --port "$WG_PORT" \
            --secret-key "$wg_priv" \
            --peer-pubkey "$unifi_pub" \
            --address "$XRAY_ADDR" \
            --mtu "$WG_MTU" \
            --keepalive "$WG_KEEPALIVE" \
            --loglevel "$LOGLEVEL" \
            "$@" \
            > "$tmpcfg" || { rm -f "$tmpcfg"; fatal "config generation failed (check the link)"; }
        # -format json is required because xray infers format from the extension.
        if [ -x "$XRAY" ]; then
            "$XRAY" run -test -config "$tmpcfg" -format json >/dev/null 2>&1 || {
                rm -f "$tmpcfg"; fatal "xray rejected the generated config (-test failed)"
            }
        fi
    fi
    mv "$tmpcfg" "$CONFIG"
    chmod 600 "$CONFIG"
    printf '%s' "$_eng" > "$ENGINE_FILE"
    _plugin_commit
}

regen_config() {
    [ -f "$OUTBOUND_LINK" ] || fatal "no proxy link imported yet. Run 'proxy' and choose option 1."
    _build_config "$(cat "$OUTBOUND_LINK")"
}

cmd_import() {
    [ $# -ge 1 ] || fatal "usage: proxy import <vless:// | vmess:// | trojan:// | ss:// | hysteria2:// | tuic:// ...>"
    link="$1"
    case "$link" in
        vless://*|vmess://*|trojan://*|ss://*|hysteria2://*|hy2://*|tuic://*) : ;;
        *) fatal "unsupported link (expected vless://, vmess://, trojan://, ss://, hysteria2:// or tuic://)" ;;
    esac
    load_settings
    # Build + validate the NEW link FIRST. On any failure this fatals before we
    # touch link.txt, so a bad import never clobbers a working configuration.
    _build_config "$link"
    mkdir -p "$ETC_DIR"
    printf '%s' "$link" > "$OUTBOUND_LINK"
    chmod 600 "$OUTBOUND_LINK"
    save_settings
    # Apply immediately (starts the service even if autostart is off; the unit's
    # ConditionPathExists is now satisfied because config.json exists).
    systemctl restart "$SERVICE_NAME" 2>/dev/null || systemctl start "$SERVICE_NAME" 2>/dev/null || true
    c_grn "Imported and applied."
    echo
    cmd_wg_config
}

cmd_wg_config() {
    [ -f "$WG_DIR/unifi_private.key" ] || fatal "no keys yet. Run 'proxy' and choose option 1 to import a link first."
    load_settings
    upriv="$(cat "$WG_DIR/unifi_private.key")"
    xpub="$(cat "$WG_DIR/wg_public.key")"
    c_bold "================  UniFi WireGuard VPN Client  ================"
    echo
    echo "In unifi.ui.com: Settings -> VPN -> VPN Client -> Create New (WireGuard)."
    echo "Either enter these manually, or upload the .conf below:"
    echo
    printf '%-19s %s\n' "Private Key:"        "$upriv"
    printf '%-19s %s\n' "Public Key (peer):"  "$xpub"
    printf '%-19s %s\n' "Endpoint:"           "${WG_LISTEN}:${WG_PORT}"
    printf '%-19s %s\n' "Pre-shared Key:"     "(leave empty)"
    printf '%-19s %s\n' "Address/Local IP:"   "$UNIFI_ADDR"
    printf '%-19s %s\n' "Allowed IPs:"        "0.0.0.0/0, ::/0"
    printf '%-19s %s\n' "MTU:"                "$WG_MTU"
    [ -n "$INNER_DNS" ] && printf '%-19s %s\n' "DNS:" "$INNER_DNS"
    echo
    c_ylw "Save this as a .conf and use 'Upload Configuration File':"
    echo "----------------------------------------------------------------"
    cat <<EOF
[Interface]
PrivateKey = $upriv
Address = $UNIFI_ADDR
$( [ -n "$INNER_DNS" ] && echo "DNS = $INNER_DNS" )
MTU = $WG_MTU

[Peer]
PublicKey = $xpub
Endpoint = ${WG_LISTEN}:${WG_PORT}
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = $WG_KEEPALIVE
EOF
    echo "----------------------------------------------------------------"
    echo
    echo "After it connects, go to Policy Engine -> Policy Table and create a"
    echo "Traffic Route that sends your chosen VLAN/clients through this VPN Client."
    c_bold "============================================================="
}

cmd_status() {
    load_settings
    act="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)"
    ena="$(systemctl is-enabled "$SERVICE_NAME" 2>/dev/null || true)"
    echo "service:   ${act:-unknown} / ${ena:-disabled}"
    _eng="$(current_engine)"
    echo "engine:    $_eng"
    if [ "$_eng" = "singbox" ]; then
        if [ -x "$SBIN" ]; then echo "core:      $("$SBIN" version 2>/dev/null | head -1)"; else echo "core:      sing-box not installed"; fi
    else
        if [ -x "$XRAY" ]; then echo "core:      $("$XRAY" version 2>/dev/null | head -1)"; else echo "core:      xray not installed"; fi
    fi
    echo "server:    $(current_server)"
    if [ -f "$PLUGIN_ENV" ] && [ -f "$PLUGIN_BIN_FILE" ]; then
        pst="$(systemctl is-active "$PLUGIN_SERVICE_NAME" 2>/dev/null || true)"
        echo "plugin:    $(basename "$(cat "$PLUGIN_BIN_FILE")") (${pst:-unknown})"
    fi
    echo "wg listen: ${WG_LISTEN}:${WG_PORT}  mtu=${WG_MTU}"
    if have ss; then
        if ss -lun 2>/dev/null | grep -q ":${WG_PORT}\b"; then c_grn "udp/${WG_PORT}: listening"; else c_ylw "udp/${WG_PORT}: not listening"; fi
    fi
}

cmd_logs()    { shift || true; journalctl -u "$SERVICE_NAME" "$@"; }
cmd_start()   { systemctl start "$SERVICE_NAME"; }
cmd_stop()    { systemctl stop "$SERVICE_NAME"; }
cmd_restart() { systemctl restart "$SERVICE_NAME"; }
cmd_enable()  { systemctl enable "$SERVICE_NAME"; }
cmd_disable() { systemctl disable "$SERVICE_NAME"; }   # autostart only; use 'stop' to stop now

cmd_config()  { [ -f "$CONFIG" ] || fatal "no config generated yet"; cat "$CONFIG"; }

cmd_set() {
    load_settings
    key="$1"; val="$2"
    # 'ping' only changes a CLI default; it never touches the xray config.
    if [ "$key" = "ping" ]; then
        case "$val" in
            get|head|tcp|icmp) PING_MODE="$val"; save_settings; c_grn "Default ping protocol = $val." ;;
            *) fatal "ping protocol must be get|head|tcp|icmp" ;;
        esac
        return
    fi
    # validate up front so a bad value is never persisted to settings.env
    case "$key" in
        port)
            case "$val" in ""|*[!0-9]*) fatal "port must be a number (1-65535)";; esac
            { [ "$val" -ge 1 ] && [ "$val" -le 65535 ]; } || fatal "port out of range (1-65535)"
            WG_PORT="$val" ;;
        mtu)
            case "$val" in ""|*[!0-9]*) fatal "mtu must be a number";; esac
            { [ "$val" -ge 576 ] && [ "$val" -le 1500 ]; } || fatal "mtu out of range (576-1500)"
            WG_MTU="$val" ;;
        keepalive)
            case "$val" in *[!0-9]*) fatal "keepalive must be a number";; esac
            WG_KEEPALIVE="${val:-0}" ;;
        dns)
            val="$(printf '%s' "$val" | tr -d ' ')"            # comma-separated, no spaces
            [ -z "$val" ] && val="8.8.8.8"                      # empty -> reset to default
            # settings.env is sourced by the shell, so reject anything that isn't a
            # plain DNS server/URL char (blocks shell-metachar injection).
            case "$val" in *[!A-Za-z0-9.:/_,+-]*) fatal "invalid DNS value (allowed: letters, digits, . : / _ , + -)";; esac
            INNER_DNS="$val" ;;
        loglevel)
            case "$val" in debug|info|warning|error|none) LOGLEVEL="$val" ;; *) fatal "loglevel must be debug|info|warning|error|none";; esac ;;
        *) fatal "unknown setting '$key' (port|mtu|dns|keepalive|loglevel|ping)" ;;
    esac
    save_settings
    if [ -f "$OUTBOUND_LINK" ]; then
        regen_config
        systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        c_grn "Updated $key and reloaded."
        case "$key" in port|mtu|dns) echo; c_ylw "Update your UniFi VPN Client to match:"; cmd_wg_config ;; esac
    else
        c_grn "Updated $key (will apply when you import a link)."
    fi
    return 0
}

cmd_regen_keys() {
    load_settings
    # Rotate atomically: if a link is configured, rebuild the config with the NEW
    # keys and only keep them if that succeeds. On failure, restore the old keys so
    # the key files always match the running config (never a silent mismatch).
    if [ -f "$OUTBOUND_LINK" ]; then
        _bk="$(mktemp -d)"
        cp -p "$WG_DIR"/*.key "$_bk"/ 2>/dev/null || true
        rm -f "$WG_DIR"/*.key
        ensure_keys
        # regen_config may call fatal() (which exits); run it in a subshell so a
        # failure is caught here as a non-zero status instead of killing the CLI
        # before we can roll the keys back. On success it has already written
        # config.json (the mv inside it is atomic), so re-running it is not needed.
        if ( regen_config ) >/dev/null 2>&1; then
            rm -rf "$_bk"
            systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else
            # roll back to the previous keypair
            rm -f "$WG_DIR"/*.key
            cp -p "$_bk"/*.key "$WG_DIR"/ 2>/dev/null || true
            rm -rf "$_bk"
            fatal "key regeneration failed (config rebuild error); previous keys kept"
        fi
    else
        rm -f "$WG_DIR"/*.key
        ensure_keys
    fi
    c_ylw "New keys generated. You MUST update the UniFi VPN Client with the new config:"
    echo
    cmd_wg_config
}

cmd_update() {
    cmd_install_binary
    systemctl restart "$SERVICE_NAME" 2>/dev/null || true
}

cmd_geo_update() {
    mkdir -p "$BIN_DIR"
    for f in geoip.dat geosite.dat; do
        info "downloading $f ..."
        if have curl; then
            curl -fsSL "$GEO_BASE/$f" -o "$BIN_DIR/$f.new" || { rm -f "$BIN_DIR/$f.new"; fatal "failed to fetch $f"; }
        elif have wget; then
            wget -qO "$BIN_DIR/$f.new" "$GEO_BASE/$f" || { rm -f "$BIN_DIR/$f.new"; fatal "failed to fetch $f"; }
        else
            fatal "need curl or wget to download geo files"
        fi
        mv -f "$BIN_DIR/$f.new" "$BIN_DIR/$f"
    done
    systemctl restart "$SERVICE_NAME" 2>/dev/null || true
    c_grn "Geo files updated."
}

# Print 'host<TAB>port' for the current link using the engine-appropriate generator.
_server_hp() {
    [ -f "$OUTBOUND_LINK" ] || return 1
    if [ "$(current_engine)" = "singbox" ]; then _gen="$MKSB"; else _gen="$MKCONFIG"; fi
    py "$_gen" --link "$(cat "$OUTBOUND_LINK")" --print-server 2>/dev/null
}

current_server() {
    [ -f "$OUTBOUND_LINK" ] || { echo "(none imported)"; return; }
    hp="$(_server_hp)" || { echo "?"; return; }
    [ -n "$hp" ] || { echo "?"; return; }
    printf '%s:%s\n' "$(printf '%s' "$hp" | cut -f1)" "$(printf '%s' "$hp" | cut -f2)"
}

# --------------------------------------------------------------------------
# Connectivity test (`proxy ping`)
# --------------------------------------------------------------------------
_ms_from_seconds() { py -c "print('%.0f'%(float('${1:-0}')*1000))" 2>/dev/null || echo "?"; }

ping_proxy() {   # $1 = get|head
    _m="$1"; _link="$(cat "$OUTBOUND_LINK")"; _e="$(current_engine)"
    _port=21080
    _cfg="$(mktemp)"
    if [ "$_e" = "singbox" ]; then
        [ -x "$SBIN" ] || { err "sing-box not installed"; return 1; }
        py "$MKSB" --link "$_link" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { rm -f "$_cfg"; err "could not build test config"; return 1; }
        "$SBIN" run -c "$_cfg" >/dev/null 2>&1 &
    else
        [ -x "$XRAY" ] || { err "xray binary not installed"; return 1; }
        py "$MKCONFIG" --link "$_link" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { rm -f "$_cfg"; err "could not build test config"; return 1; }
        # -format json: mktemp names have no extension for xray to infer the format from.
        "$XRAY" run -config "$_cfg" -format json >/dev/null 2>&1 &
    fi
    _pid=$!
    # wait (max ~4.5s) for the SOCKS listener to come up
    _i=0
    while [ "$_i" -lt 15 ]; do
        if py -c 'import socket,sys;s=socket.socket();s.settimeout(0.5)
try:
    s.connect(("127.0.0.1",'"$_port"'));s.close()
except Exception: sys.exit(1)' >/dev/null 2>&1; then break; fi
        _i=$((_i + 1)); sleep 0.3 2>/dev/null || sleep 1
    done
    if [ "$_m" = "head" ]; then _label="via proxy (HEAD)"; set -- -I; else _label="via proxy (GET)"; set -- -X GET; fi
    # LC_ALL=C so curl prints time_total with a '.' decimal regardless of locale
    _out="$(LC_ALL=C curl -sS -o /dev/null -w '%{http_code} %{time_total}' --max-time "$PING_TIMEOUT" \
             "$@" --proxy "socks5h://127.0.0.1:${_port}" "$PING_URL" 2>/dev/null)" || _out=""
    kill "$_pid" 2>/dev/null || true; wait "$_pid" 2>/dev/null || true
    rm -f "$_cfg"
    if [ -z "$_out" ]; then c_red "${_label}: timeout (>${PING_TIMEOUT}s)"; return 1; fi
    _code="${_out%% *}"; _ms="$(_ms_from_seconds "${_out##* }")"
    case "$_code" in
        204|200) c_grn "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
        *)       c_ylw "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
    esac
}

ping_tcp() {
    _hp="$(_server_hp)"
    _h="$(printf '%s' "$_hp" | cut -f1)"; _p="$(printf '%s' "$_hp" | cut -f2)"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    _ms="$(py - "$_h" "$_p" "$PING_TIMEOUT" <<'PYEOF'
import socket, time, sys
host, port, timeout = sys.argv[1], int(sys.argv[2]), float(sys.argv[3])
start = time.time()
try:
    socket.create_connection((host, port), timeout=timeout).close()
    print("%.0f" % ((time.time() - start) * 1000))
except Exception:
    sys.exit(1)
PYEOF
)" || { c_red "TCP ${_h}:${_p}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    c_grn "TCP ${_h}:${_p}: ${_ms} ms"
}

ping_icmp() {
    _hp="$(_server_hp)"
    _h="$(printf '%s' "$_hp" | cut -f1)"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    _out="$(ping -c 1 -W "$PING_TIMEOUT" "$_h" 2>/dev/null)" || { c_red "ICMP ${_h}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    _ms="$(printf '%s\n' "$_out" | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -1)"
    if [ -n "$_ms" ]; then c_grn "ICMP ${_h}: ${_ms} ms"; else c_red "ICMP ${_h}: no reply (host may block ICMP)"; fi
}

cmd_ping() {
    load_settings
    if [ ! -f "$OUTBOUND_LINK" ]; then
        c_ylw "No proxy link imported. Import one first (run 'proxy' -> option 1)."
        return 1
    fi
    _mode="${1:-$PING_MODE}"
    case "$_mode" in
        get)  ping_proxy get ;;
        head) ping_proxy head ;;
        tcp)  ping_tcp ;;
        icmp) ping_icmp ;;
        *) fatal "unknown ping protocol '$_mode' (get|head|tcp|icmp)" ;;
    esac
}

# --------------------------------------------------------------------------
# Interactive menu (shown when `proxy` is run with no arguments)
# --------------------------------------------------------------------------
pause() { printf '\n'; printf 'Press Enter to return to the menu...'; read -r _ || true; }

print_menu() {
    load_settings
    HR="$(py -c "print('─'*51)" 2>/dev/null || printf '%0.s─' 1 2 3 4 5)"
    svc="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || echo unknown)"
    auto="$(systemctl is-enabled "$SERVICE_NAME" 2>/dev/null || echo disabled)"
    lst="down"; if have ss && ss -lun 2>/dev/null | grep -q ":${WG_PORT}\b"; then lst="up"; fi
    ml() { printf '│ %-49s │\n' "$1"; }
    case "$svc" in active) svc_d="Running";; inactive) svc_d="Stopped";; *) svc_d="$svc";; esac
    case "$auto" in enabled) auto_d="Yes";; *) auto_d="No";; esac

    printf '\n'
    printf '╔%s╗\n' "$HR"
    ml "  proxy-unifi : multi-core proxy client"
    ml "  0. Exit Script"
    printf '│%s│\n' "$HR"
    ml "  1. Import / replace proxy link"
    ml "  2. Show current server & config"
    ml "  3. Show UniFi WireGuard VPN Client config"
    ml "  4. Regenerate WireGuard keys"
    printf '│%s│\n' "$HR"
    ml "  5. Change WireGuard port"
    ml "  6. Change tunnel MTU"
    ml "  7. Change tunnel DNS"
    printf '│%s│\n' "$HR"
    ml "  8. Ping test"
    ml "  9. Change test algorithm"
    printf '│%s│\n' "$HR"
    ml " 10. Start"
    ml " 11. Stop"
    ml " 12. Restart"
    ml " 13. Check status"
    ml " 14. View logs"
    printf '│%s│\n' "$HR"
    ml " 15. Enable autostart"
    ml " 16. Disable autostart"
    printf '│%s│\n' "$HR"
    ml " 17. Update xray-core"
    ml " 18. Update geo files"
    ml " 19. Version info"
    ml " 20. Uninstall"
    printf '╚%s╝\n' "$HR"
    printf '\n'
    printf 'Service:    %s\n' "$svc_d"
    printf 'Autostart:  %s\n' "$auto_d"
    printf 'Listener:   udp %s:%s (%s)\n' "$WG_LISTEN" "$WG_PORT" "$lst"
    printf 'Server:     %s\n' "$(current_server)"
}

# State-aware service controls used by the menu (idempotent feedback).
menu_start() {
    if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Service is already running."
    elif systemctl start "$SERVICE_NAME" 2>/dev/null;          then c_grn "Service started."
    else c_red "Failed to start - is a link imported? Check 'View logs'."; fi
}
menu_stop() {
    if ! systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Service is already stopped."
    elif systemctl stop "$SERVICE_NAME" 2>/dev/null;             then c_ylw "Service stopped."
    else c_red "Failed to stop service."; fi
}
menu_restart() {
    if systemctl restart "$SERVICE_NAME" 2>/dev/null; then c_grn "Service restarted."
    else c_red "Failed to restart - is a link imported? Check 'View logs'."; fi
}
menu_enable() {
    if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Autostart is already enabled."
    elif systemctl enable "$SERVICE_NAME" >/dev/null 2>&1;       then c_grn "Autostart enabled."
    else c_red "Failed to enable autostart (is the service installed?)."; fi
}
menu_disable() {
    if ! systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Autostart is already disabled."
    elif systemctl disable "$SERVICE_NAME" >/dev/null 2>&1;        then c_ylw "Autostart disabled (service keeps running until stopped)."
    else c_red "Failed to disable autostart."; fi
}

menu_set_ping() {
    load_settings
    _cur="$(printf '%s' "$PING_MODE" | tr '[:lower:]' '[:upper:]')"
    echo "Choose default ping protocol (currently selected: ${_cur}):"
    echo "  1. via proxy (GET)    - real delay through the proxy tunnel"
    echo "  2. via proxy (HEAD)   - same, HEAD request"
    echo "  3. TCP                - handshake latency to the server"
    echo "  4. ICMP               - echo to the server host"
    printf 'Choice [Enter = 1]: '
    read -r _p || true
    case "${_p:-1}" in
        1) _m="get" ;; 2) _m="head" ;; 3) _m="tcp" ;; 4) _m="icmp" ;;
        *) c_red "invalid choice"; return ;;
    esac
    cmd_set ping "$_m"
}

cmd_menu() {
    # Interactive loop: turn off errexit and run each action in a subshell so a
    # failing action (including any fatal/exit) reports its error and returns to
    # the menu instead of killing the whole program.
    set +e
    while true; do
        clear 2>/dev/null || true
        print_menu
        printf '\nPlease enter your selection [0-20]: '
        read -r sel || exit 0
        echo
        case "$sel" in
            0)  exit 0 ;;
            1)  ( printf 'Paste proxy link (vless/vmess/trojan/ss/hysteria2/tuic): '; read -r _l || true
                  if [ -n "${_l:-}" ]; then cmd_import "$_l"; else c_ylw "No link entered."; fi ) ;;
            2)  ( cmd_config ) ;;
            3)  ( cmd_wg_config ) ;;
            4)  ( printf 'Regenerate keys? This breaks the current UniFi VPN Client until you re-paste the new config. [y/N]: '
                  read -r _c || true
                  if [ "${_c:-}" = "y" ]; then cmd_regen_keys; else c_ylw "Cancelled."; fi ) ;;
            5)  ( printf 'New WireGuard UDP port [%s]: ' "$WG_PORT"; read -r _v || true
                  if [ -n "${_v:-}" ]; then cmd_set port "$_v"; else c_ylw "Unchanged."; fi ) ;;
            6)  ( printf 'New tunnel MTU [%s]: ' "$WG_MTU"; read -r _v || true
                  if [ -n "${_v:-}" ]; then cmd_set mtu "$_v"; else c_ylw "Unchanged."; fi ) ;;
            7)  ( printf 'Tunnel DNS (comma-separated, empty to reset to 8.8.8.8) [%s]: ' "$INNER_DNS"; read -r _v || true
                  cmd_set dns "${_v:-}" ) ;;
            8)  ( cmd_ping ) ;;
            9)  ( menu_set_ping ) ;;
            10) ( menu_start ) ;;
            11) ( menu_stop ) ;;
            12) ( menu_restart ) ;;
            13) ( cmd_status ) ;;
            14) ( printf 'Lines to show [100]: '; read -r _n || true
                  case "${_n:-}" in ""|*[!0-9]*) _n=100 ;; esac
                  cmd_logs logs -n "$_n" --no-pager ) ;;
            15) ( menu_enable ) ;;
            16) ( menu_disable ) ;;
            17) ( cmd_update ) ;;
            18) ( cmd_geo_update ) ;;
            19) ( if [ -x "$XRAY" ]; then "$XRAY" version | head -1; else c_ylw "xray-core: not installed"; fi
                  echo "proxy-unifi CLI 1.0.0" ) ;;
            20) printf 'Really uninstall the service + boot hook? [y/N]: '; read -r _c || true
                if [ "${_c:-}" = "y" ]; then ( cmd_uninstall ); pause; exit 0; else c_ylw "Cancelled."; fi ;;
            *)  c_red "Invalid selection." ;;
        esac
        pause
    done
}

cmd_uninstall() {
    need_root
    systemctl disable --now "$SERVICE_NAME" 2>/dev/null || true
    systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
    rm -f "$SERVICE_FILE" "$PLUGIN_SERVICE_FILE" "$ONBOOT_DST" /usr/bin/proxy
    systemctl daemon-reload 2>/dev/null || true
    c_ylw "Removed service + boot hook. Data kept at $ROOT (delete it manually to purge keys/config)."
    info "Don't forget to delete the WireGuard VPN Client in the UniFi UI."
}

usage() {
    cat <<EOF
proxy - multi-core proxy client (xray-core + sing-box) for UniFi gateways

Run 'proxy' with no arguments for the interactive management menu
(import links, keys, WireGuard config, updates, uninstall, etc.).

Direct commands (for scripting / quick ops):
  proxy start        Start the service
  proxy stop         Stop the service
  proxy restart      Restart the service
  proxy status       Show engine / server / listener status
  proxy ping [proto] Test the proxy link; proto = get|head|tcp|icmp (default: get)
  proxy logs [args]  Tail service logs (passes args to journalctl)
  proxy help         This help

Data lives in $ROOT and survives reboots/firmware upgrades via unifi-common.
EOF
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------
load_settings
cmd="${1:-}"; [ $# -ge 1 ] && shift || true
case "$cmd" in
    # interactive menu (default)
    "")           need_root; cmd_menu ;;
    # kept direct commands
    start)        need_root; cmd_start ;;
    stop)         need_root; cmd_stop ;;
    restart)      need_root; cmd_restart ;;
    status)       cmd_status ;;
    ping)         cmd_ping "$@" ;;
    logs)         cmd_logs logs "$@" ;;
    -h|--help|help) usage ;;
    # internal / hidden (used by installer, boot hook, and the menu)
    menu)            need_root; cmd_menu ;;
    import)          need_root; cmd_import "$@" ;;
    wg-config|wg)    cmd_wg_config ;;
    config)          cmd_config ;;
    set)             need_root; [ $# -ge 2 ] || fatal "usage: proxy set <key> <value>"; cmd_set "$1" "$2" ;;
    regen-keys)      need_root; cmd_regen_keys ;;
    enable)          need_root; cmd_enable ;;
    disable)         need_root; cmd_disable ;;
    update)          need_root; cmd_update ;;
    geo-update)      need_root; cmd_geo_update ;;
    version)         [ -x "$XRAY" ] && "$XRAY" version | head -1; echo "proxy-unifi CLI 1.0.0" ;;
    uninstall)       cmd_uninstall ;;
    install-binary)  need_root; cmd_install_binary ;;
    install-service) need_root; install_service ;;
    *) err "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
